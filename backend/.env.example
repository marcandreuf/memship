# Database
DATABASE_URL=postgresql://memship:memship@localhost:5433/memship_db
DATABASE_TEST_URL=postgresql://memship:memship@localhost:5434/memship_test_db

# Security
SECRET_KEY=change-me-in-production-use-a-random-64-char-string
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Application
APP_ENV=development
DEFAULT_LOCALE=es
CORS_ORIGINS=http://localhost:3000

# SMTP (optional — leave SMTP_HOST empty to disable emails)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@memship.local
SMTP_TLS=true
FRONTEND_URL=http://localhost:3000

# Server
HOST=0.0.0.0
PORT=8000
