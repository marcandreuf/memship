# Memship Backend — Local Development
# Copy this file to .env for running outside Docker

# Database
DATABASE_URL=postgresql://memship:memship@localhost:5433/memship_db
DATABASE_TEST_URL=postgresql://memship:memship@localhost:5434/memship_test_db

# Security
SECRET_KEY=change-me-in-production-use-a-random-64-char-string
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Application
APP_ENV=development
DEFAULT_LOCALE=es
CORS_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Email — Resend (preferred, managed delivery)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Email — SMTP (alternative, self-hosted)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@memship.local
SMTP_TLS=true

# Celery (Redis)
CELERY_BROKER_URL=redis://localhost:6379/0

# Server
HOST=0.0.0.0
PORT=8000
