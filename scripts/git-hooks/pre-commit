#!/bin/bash
# Memship Pre-Commit Hook
# Prompts for version tag before commits.
# Current version is read from the latest git tag (source of truth).
# Updates VERSION file and creates git tag after commit.

set -e

PROJECT_ROOT="$(git rev-parse --show-toplevel)"
VERSION_FILE="$PROJECT_ROOT/VERSION"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# Check if we can interact with the user via /dev/tty
if [[ ! -e /dev/tty ]]; then
    exit 0
fi

# Get current version from latest git tag (source of truth)
CURRENT_VERSION=$(git describe --tags --abbrev=0 2>/dev/null | sed 's/^v//')
if [[ -z "$CURRENT_VERSION" ]]; then
    CURRENT_VERSION="0.0.0"
fi
IFS='.' read -r MAJOR MINOR PATCH <<< "$CURRENT_VERSION"

# Show staged files
STAGED_FILES=$(git diff --cached --name-only)

echo ""
echo -e "${BLUE}в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ${NC}"
echo -e "${BLUE}                MEMSHIP VERSION CHECK                       ${NC}"
echo -e "${BLUE}в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ${NC}"
echo ""
echo -e "${YELLOW}Staged files:${NC}"
echo "$STAGED_FILES" | head -10 | sed 's/^/  /'
if [[ $(echo "$STAGED_FILES" | wc -l) -gt 10 ]]; then
    echo "  ... and more"
fi
echo ""
echo -e "Current version (latest tag): ${GREEN}$CURRENT_VERSION${NC}"
echo ""

# Show suggested versions and ask for input
PATCH_VERSION="$MAJOR.$MINOR.$((PATCH + 1))"
MINOR_VERSION="$MAJOR.$((MINOR + 1)).0"
MAJOR_VERSION="$((MAJOR + 1)).0.0"

echo "Version for this commit? Enter a semver or pick a suggestion:"
echo ""
echo -e "  Suggestions:  ${GREEN}$PATCH_VERSION${NC}  |  ${GREEN}$MINOR_VERSION${NC}  |  ${GREEN}$MAJOR_VERSION${NC}"
echo ""
read -p "  Version (empty to skip): " NEW_VERSION < /dev/tty

# Skip if empty
if [[ -z "$NEW_VERSION" ]]; then
    echo -e "${YELLOW}Version update skipped${NC}"
    echo ""
    exit 0
fi

# Validate semver format
if [[ ! "$NEW_VERSION" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
    echo -e "${RED}Invalid version format: $NEW_VERSION (expected X.Y.Z)${NC}"
    echo -e "${YELLOW}Version update skipped${NC}"
    exit 0
fi

# Check if tag already exists
if git tag -l "v$NEW_VERSION" | grep -q "v$NEW_VERSION"; then
    echo -e "${RED}Tag v$NEW_VERSION already exists${NC}"
    echo -e "${YELLOW}Version update skipped${NC}"
    exit 0
fi

# Update VERSION file and stage it
echo "$NEW_VERSION" > "$VERSION_FILE"
git add "$VERSION_FILE"

echo ""
echo -e "${GREEN}Version: $CURRENT_VERSION в†’ $NEW_VERSION${NC}"
echo ""

# --- Check README roadmap ---

README_EN="$PROJECT_ROOT/README.md"
if grep -q "| v$NEW_VERSION " "$README_EN" 2>/dev/null; then
    echo -e "${GREEN}v$NEW_VERSION found in README roadmap${NC}"
else
    echo -e "${YELLOW}Warning: v$NEW_VERSION not found in README.md roadmap${NC}"
    echo -e "${YELLOW}Consider updating the roadmaps before committing${NC}"
    echo ""
    read -p "Continue anyway? [y/N]: " continue_anyway < /dev/tty
    if [[ ! "$continue_anyway" =~ ^[Yy]$ ]]; then
        # Revert VERSION file to match current tag
        echo "$CURRENT_VERSION" > "$VERSION_FILE"
        git add "$VERSION_FILE"
        echo -e "${RED}Commit aborted вЂ” update READMEs first${NC}"
        exit 1
    fi
fi

echo ""

# Create tag after commit (via post-commit hook)
echo "$NEW_VERSION" > "$PROJECT_ROOT/.pending-tag"
echo -e "${GREEN}Tag v$NEW_VERSION will be created after commit${NC}"
echo ""
