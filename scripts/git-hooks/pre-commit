#!/bin/bash
# Memship Pre-Commit Hook
# Prompts for version bump before commits that affect deployable code

set -e

PROJECT_ROOT="$(git rev-parse --show-toplevel)"
VERSION_FILE="$PROJECT_ROOT/VERSION"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# Check if we can interact with the user via /dev/tty
if [[ ! -e /dev/tty ]]; then
    exit 0
fi

# Check if VERSION file exists
if [[ ! -f "$VERSION_FILE" ]]; then
    echo -e "${YELLOW}Warning: VERSION file not found, skipping version check${NC}"
    exit 0
fi

# Get list of staged files
STAGED_FILES=$(git diff --cached --name-only)

# Check if any deployable code is being committed
DEPLOYABLE_PATTERNS="^backend/|^frontend/"
DEPLOYABLE_CHANGES=$(echo "$STAGED_FILES" | grep -E "$DEPLOYABLE_PATTERNS" || true)

if [[ -z "$DEPLOYABLE_CHANGES" ]]; then
    exit 0
fi

# Check if VERSION file is already staged (already bumped)
if echo "$STAGED_FILES" | grep -q "^VERSION$"; then
    exit 0
fi

# Show current version and changes
CURRENT_VERSION=$(cat "$VERSION_FILE" | tr -d '[:space:]')
echo ""
echo -e "${BLUE}═══════════════════════════════════════════════════════════${NC}"
echo -e "${BLUE}                MEMSHIP VERSION CHECK                       ${NC}"
echo -e "${BLUE}═══════════════════════════════════════════════════════════${NC}"
echo ""
echo -e "${YELLOW}Deployable code changes detected:${NC}"
echo "$DEPLOYABLE_CHANGES" | head -10 | sed 's/^/  /'
if [[ $(echo "$DEPLOYABLE_CHANGES" | wc -l) -gt 10 ]]; then
    echo "  ... and more"
fi
echo ""
echo -e "Current version: ${GREEN}$CURRENT_VERSION${NC}"
echo ""

# Parse version
IFS='.' read -r MAJOR MINOR PATCH <<< "$CURRENT_VERSION"

# Prompt for version bump
echo "Do you want to bump the version for this commit?"
echo ""
echo "  1) patch  → $MAJOR.$MINOR.$((PATCH + 1))  (bug fixes, small changes)"
echo "  2) minor  → $MAJOR.$((MINOR + 1)).0  (new features)"
echo "  3) major  → $((MAJOR + 1)).0.0  (breaking changes)"
echo "  4) skip   → Keep $CURRENT_VERSION (no version bump)"
echo ""
read -p "Enter choice [1-4] (default: 4): " choice < /dev/tty

case ${choice:-4} in
    1)
        NEW_VERSION="$MAJOR.$MINOR.$((PATCH + 1))"
        ;;
    2)
        NEW_VERSION="$MAJOR.$((MINOR + 1)).0"
        ;;
    3)
        NEW_VERSION="$((MAJOR + 1)).0.0"
        ;;
    4)
        echo -e "${YELLOW}Version bump skipped${NC}"
        echo ""
        exit 0
        ;;
    *)
        echo -e "${RED}Invalid choice, version bump skipped${NC}"
        exit 0
        ;;
esac

# Update VERSION file
echo "$NEW_VERSION" > "$VERSION_FILE"

# Stage the VERSION file
git add "$VERSION_FILE"

echo ""
echo -e "${GREEN}Version bumped: $CURRENT_VERSION → $NEW_VERSION${NC}"
echo -e "${GREEN}VERSION file staged for commit${NC}"
echo ""

# Ask about creating git tag
read -p "Create git tag v$NEW_VERSION after commit? [y/N]: " create_tag < /dev/tty
if [[ "$create_tag" =~ ^[Yy]$ ]]; then
    echo "$NEW_VERSION" > "$PROJECT_ROOT/.pending-tag"
    echo -e "${BLUE}Tag v$NEW_VERSION will be created after commit${NC}"
fi

echo ""
