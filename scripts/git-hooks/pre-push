#!/bin/bash
# Memship Pre-Push Hook
# Automatically pushes tags that were created during commit

PROJECT_ROOT="$(git rev-parse --show-toplevel)"
PENDING_TAG_PUSH_FILE="$PROJECT_ROOT/.pending-tag-push"

# Colors
GREEN='\033[0;32m'
BLUE='\033[0;34m'
NC='\033[0m'

if [[ -f "$PENDING_TAG_PUSH_FILE" ]]; then
    VERSION=$(cat "$PENDING_TAG_PUSH_FILE" | tr -d '[:space:]')
    rm -f "$PENDING_TAG_PUSH_FILE"

    if [[ -n "$VERSION" ]]; then
        TAG_NAME="v$VERSION"

        if git tag -l | grep -q "^${TAG_NAME}$"; then
            echo ""
            echo -e "${BLUE}Pushing tag ${TAG_NAME}...${NC}"
            git push origin "$TAG_NAME" 2>/dev/null
            if [[ $? -eq 0 ]]; then
                echo -e "${GREEN}Tag ${TAG_NAME} pushed successfully${NC}"
            else
                echo "Note: Could not push tag ${TAG_NAME} (may already exist remotely)"
            fi
            echo ""
        fi
    fi
fi

exit 0
