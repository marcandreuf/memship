# Memship Configuration
# Copy this file to .env and adjust as needed

# Image version (leave empty to build locally, or set to a version like 0.3.0)
# IMAGE_TAG=0.3.0

# Ports (defaults shown)
# HTTP_PORT=80
# HTTPS_PORT=443
# API_PORT=8003
# DB_PORT=5433

# Database
DB_PASSWORD=memship

# Security (CHANGE THIS in production!)
SECRET_KEY=change-me-in-production-use-a-random-64-char-string

# Application
APP_ENV=production
DEFAULT_LOCALE=es
CORS_ORIGINS=http://localhost
FRONTEND_URL=http://localhost

# Email — Resend (preferred, managed delivery)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Email — SMTP (alternative, self-hosted)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@memship.local
SMTP_TLS=true

# Celery (Redis — included in Docker Compose)
# CELERY_BROKER_URL=redis://redis:6379/0
